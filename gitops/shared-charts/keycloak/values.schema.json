{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Keycloak Helm Chart Values",
  "description": "Configuration values for the Keycloak Helm chart. Deploys Keycloak identity and access management with dev or production mode, PostgreSQL/MySQL support, clustering, and realm import.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "mode": {
      "type": "string",
      "description": "Keycloak runtime mode: dev | production",
      "enum": ["dev", "production"]
    },
    "nameOverride": {
      "type": "string",
      "description": "Override chart name"
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override full release name"
    },
    "commonLabels": {
      "type": "object",
      "description": "Labels added to all resources"
    },
    "clusterDomain": {
      "type": "string",
      "description": "Kubernetes cluster domain"
    },
    "image": {
      "type": "object",
      "description": "Keycloak container image settings",
      "properties": {
        "repository": {
          "type": "string",
          "description": "Keycloak image repository"
        },
        "tag": {
          "type": "string",
          "description": "Keycloak image tag"
        },
        "pullPolicy": {
          "type": "string",
          "description": "Image pull policy",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets for private registries",
      "items": { "type": "object" }
    },
    "admin": {
      "type": "object",
      "description": "Bootstrap admin credentials",
      "properties": {
        "username": {
          "type": "string",
          "description": "Bootstrap admin username used on first startup"
        },
        "password": {
          "type": "string",
          "description": "Bootstrap admin password. Auto-generated if empty and no existingSecret is set."
        },
        "existingSecret": {
          "type": "string",
          "description": "Existing secret containing bootstrap admin credentials"
        },
        "existingSecretUsernameKey": {
          "type": "string",
          "description": "Secret key for admin username in admin.existingSecret"
        },
        "existingSecretPasswordKey": {
          "type": "string",
          "description": "Secret key for admin password in admin.existingSecret"
        }
      }
    },
    "http": {
      "type": "object",
      "description": "HTTP and management interface configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Keep HTTP enabled inside the cluster"
        },
        "port": {
          "type": "integer",
          "description": "Application HTTP port"
        },
        "managementPort": {
          "type": "integer",
          "description": "Management interface port used for health and metrics"
        },
        "relativePath": {
          "type": "string",
          "description": "HTTP relative path, for example /auth"
        }
      }
    },
    "management": {
      "type": "object",
      "description": "Keycloak management interface configuration",
      "properties": {
        "healthEnabled": {
          "type": "boolean",
          "description": "Serve health endpoints from the management interface"
        },
        "relativePath": {
          "type": "string",
          "description": "Optional management interface relative path"
        }
      }
    },
    "deployment": {
      "type": "object",
      "description": "Deployment lifecycle settings",
      "properties": {
        "strategy": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["RollingUpdate", "Recreate"] },
            "rollingUpdate": {
              "type": "object",
              "properties": {
                "maxUnavailable": { "type": ["string", "integer"] },
                "maxSurge": { "type": ["string", "integer"] }
              }
            }
          }
        }
      }
    },
    "hostname": {
      "type": "object",
      "description": "Hostname and reverse proxy configuration",
      "properties": {
        "hostname": {
          "type": "string",
          "description": "Public Keycloak hostname or URL. Required in production mode."
        },
        "admin": {
          "type": "string",
          "description": "Optional dedicated admin hostname or URL"
        },
        "strict": {
          "type": "boolean",
          "description": "Enforce strict hostname handling"
        },
        "backchannelDynamic": {
          "type": "boolean",
          "description": "Enable dynamic backchannel URL resolution"
        }
      }
    },
    "proxy": {
      "type": "object",
      "description": "Reverse proxy settings",
      "properties": {
        "headers": {
          "type": "string",
          "description": "Proxy headers mode passed to Keycloak, for example xforwarded or forwarded",
          "enum": ["", "xforwarded", "forwarded"]
        },
        "trustedAddresses": {
          "type": "string",
          "description": "Comma-separated trusted proxy IPs/CIDRs used by Keycloak when proxy.headers is set"
        },
        "protocolEnabled": {
          "type": "boolean",
          "description": "Enable HAProxy PROXY protocol support"
        }
      }
    },
    "database": {
      "type": "object",
      "description": "Database configuration",
      "properties": {
        "external": {
          "type": "object",
          "description": "External database connection settings",
          "properties": {
            "vendor": {
              "type": "string",
              "description": "External database vendor: postgres | mysql | mariadb",
              "enum": ["postgres", "mysql", "mariadb"]
            },
            "host": {
              "type": "string",
              "description": "External database host"
            },
            "port": {
              "type": ["string", "integer"],
              "description": "External database port (auto-detected from vendor when empty)"
            },
            "name": {
              "type": "string",
              "description": "External database name"
            },
            "username": {
              "type": "string",
              "description": "External database username"
            },
            "password": {
              "type": "string",
              "description": "External database password"
            },
            "existingSecret": {
              "type": "string",
              "description": "Existing secret containing database password"
            },
            "existingSecretPasswordKey": {
              "type": "string",
              "description": "Secret key for database password in database.external.existingSecret"
            },
            "jdbcParameters": {
              "type": "string",
              "description": "Additional JDBC properties appended to the generated JDBC URL"
            },
            "schema": {
              "type": "string",
              "description": "Optional database schema passed to KC_DB_SCHEMA"
            },
            "pool": {
              "type": "object",
              "description": "Database connection pool settings",
              "properties": {
                "initialSize": { "type": ["string", "integer"], "description": "Initial database connection pool size" },
                "minSize": { "type": ["string", "integer"], "description": "Minimum database connection pool size" },
                "maxSize": { "type": ["string", "integer"], "description": "Maximum database connection pool size" },
                "maxLifetime": { "type": "string", "description": "Maximum database connection lifetime" }
              }
            },
            "logSlowQueriesThreshold": {
              "type": "string",
              "description": "Slow query threshold passed to Keycloak"
            },
            "transaction": {
              "type": "object",
              "description": "Database transaction settings",
              "properties": {
                "xaEnabled": { "type": ["string", "boolean"], "description": "Enable or disable XA transactions" },
                "timeout": { "type": "string", "description": "Transaction timeout" }
              }
            }
          }
        },
        "tls": {
          "type": "object",
          "description": "Database TLS settings",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable database TLS settings"
            },
            "mode": {
              "type": "string",
              "description": "Keycloak database TLS mode",
              "enum": ["", "disabled", "verify-server"]
            },
            "sslMode": {
              "type": "string",
              "description": "PostgreSQL SSL mode used when database.tls.enabled is true"
            },
            "mountPath": {
              "type": "string",
              "description": "Mount path for database TLS material"
            },
            "rootCertFilename": {
              "type": "string",
              "description": "Root CA filename mounted under database.tls.mountPath"
            },
            "existingSecret": {
              "type": "string",
              "description": "Existing secret holding database CA material"
            },
            "existingConfigMap": {
              "type": "string",
              "description": "Existing ConfigMap holding database CA material"
            },
            "trustStoreFile": {
              "type": "string",
              "description": "Database TLS truststore file path passed to Keycloak"
            },
            "trustStorePasswordSecret": {
              "type": "string",
              "description": "Existing Secret containing the database TLS truststore password"
            },
            "trustStorePasswordKey": {
              "type": "string",
              "description": "Secret key for database TLS truststore password"
            },
            "trustStoreType": {
              "type": "string",
              "description": "Database TLS truststore type"
            }
          }
        }
      }
    },
    "backup": {
      "type": "object",
      "description": "Built-in backup CronJob configuration for database-backed modes",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable built-in backup CronJob support for database-backed modes"
        },
        "schedule": {
          "type": "string",
          "description": "Backup schedule in Cron format"
        },
        "suspend": {
          "type": "boolean",
          "description": "Suspend backup execution"
        },
        "concurrencyPolicy": {
          "type": "string",
          "description": "CronJob concurrency policy",
          "enum": ["Forbid", "Replace", "Allow"]
        },
        "successfulJobsHistoryLimit": {
          "type": "integer",
          "description": "Successful job history retained by the CronJob"
        },
        "failedJobsHistoryLimit": {
          "type": "integer",
          "description": "Failed job history retained by the CronJob"
        },
        "backoffLimit": {
          "type": "integer",
          "description": "Job backoff limit"
        },
        "archivePrefix": {
          "type": "string",
          "description": "Prefix used in generated backup archive names"
        },
        "resources": {
          "type": "object",
          "description": "Resources applied to the backup dump and upload containers"
        },
        "images": {
          "type": "object",
          "description": "Container images used by backup jobs",
          "properties": {
            "uploader": {
              "type": "object",
              "properties": {
                "repository": { "type": "string" },
                "tag": { "type": "string" },
                "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
              }
            },
            "postgresql": {
              "type": "object",
              "properties": {
                "repository": { "type": "string" },
                "tag": { "type": "string" },
                "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
              }
            },
            "mysql": {
              "type": "object",
              "properties": {
                "repository": { "type": "string" },
                "tag": { "type": "string" },
                "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
              }
            }
          }
        },
        "s3": {
          "type": "object",
          "description": "S3-compatible storage configuration for backups",
          "properties": {
            "endpoint": { "type": "string", "description": "S3-compatible endpoint URL" },
            "bucket": { "type": "string", "description": "Target bucket name" },
            "prefix": { "type": "string", "description": "Optional key prefix inside the bucket" },
            "createBucketIfNotExists": { "type": "boolean", "description": "Create the bucket automatically when it does not exist yet" },
            "existingSecret": { "type": "string", "description": "Existing secret containing access-key and secret-key" },
            "existingSecretAccessKeyKey": { "type": "string", "description": "Secret key name for the access key inside backup.s3.existingSecret" },
            "existingSecretSecretKeyKey": { "type": "string", "description": "Secret key name for the secret key inside backup.s3.existingSecret" },
            "accessKey": { "type": "string", "description": "Inline access key used when backup.s3.existingSecret is not set" },
            "secretKey": { "type": "string", "description": "Inline secret key used when backup.s3.existingSecret is not set" }
          }
        },
        "database": {
          "type": "object",
          "description": "Database dump configuration",
          "properties": {
            "postgresDumpArgs": { "type": "string", "description": "Extra arguments passed to pg_dump" },
            "mysqlDumpArgs": { "type": "string", "description": "Extra arguments passed to mysqldump" }
          }
        }
      }
    },
    "truststore": {
      "type": "object",
      "description": "Additional trusted certificates for outbound TLS connections",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable additional trusted certificates for outbound TLS connections used by Keycloak"
        },
        "mountPath": {
          "type": "string",
          "description": "Mount path added to Keycloak truststore paths"
        },
        "existingSecret": {
          "type": "string",
          "description": "Existing secret holding PEM or unencrypted PKCS12 trust material"
        },
        "existingConfigMap": {
          "type": "string",
          "description": "Existing ConfigMap holding PEM or unencrypted PKCS12 trust material"
        },
        "tlsHostnameVerifier": {
          "type": "string",
          "description": "TLS hostname verification mode for outbound HTTPS and SMTP traffic",
          "enum": ["DEFAULT", "ANY", "WILDCARD", "STRICT"]
        },
        "kubernetes": {
          "type": "object",
          "description": "Kubernetes/OpenShift service account CA truststore handling",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Let Keycloak trust Kubernetes/OpenShift service account CA files when mounted"
            }
          }
        }
      }
    },
    "replicaCount": {
      "type": "integer",
      "description": "Number of Keycloak replicas"
    },
    "cache": {
      "type": "object",
      "description": "Distributed cache and clustering settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable distributed cache settings in production mode"
        },
        "stack": {
          "type": "string",
          "description": "Cache stack used when replicaCount > 1 in production mode"
        },
        "multiReplicaDefaults": {
          "type": "object",
          "description": "Production-oriented scheduling defaults for multi-replica deployments",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Apply production-oriented scheduling defaults when replicaCount > 1"
            },
            "podAntiAffinity": {
              "type": "string",
              "description": "Pod anti-affinity mode automatically applied for multi-replica deployments",
              "enum": ["preferred", "required", "none"]
            },
            "topologySpread": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Apply a topology spread constraint automatically for multi-replica deployments"
                },
                "topologyKey": {
                  "type": "string",
                  "description": "Topology key used by the generated spread constraint"
                },
                "whenUnsatisfiable": {
                  "type": "string",
                  "description": "whenUnsatisfiable policy used by the generated spread constraint",
                  "enum": ["DoNotSchedule", "ScheduleAnyway"]
                }
              }
            }
          }
        }
      }
    },
    "features": {
      "type": "object",
      "description": "Keycloak feature flags",
      "properties": {
        "enabled": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Keycloak features to enable"
        },
        "disabled": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Keycloak features to disable"
        }
      }
    },
    "optimized": {
      "type": "object",
      "description": "Optimized startup settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Add --optimized to Keycloak startup args"
        }
      }
    },
    "realmImport": {
      "type": "object",
      "description": "Startup realm import configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable startup realm import using --import-realm"
        },
        "files": {
          "type": "object",
          "description": "Inline realm files written to a generated ConfigMap"
        },
        "existingConfigMap": {
          "type": "string",
          "description": "Existing ConfigMap mounted into /opt/keycloak/data/import"
        }
      }
    },
    "extensions": {
      "type": "object",
      "description": "Providers and themes configuration",
      "properties": {
        "providers": {
          "type": "object",
          "properties": {
            "existingConfigMap": { "type": "string", "description": "Existing ConfigMap mounted into /opt/keycloak/providers" },
            "existingSecret": { "type": "string", "description": "Existing Secret mounted into /opt/keycloak/providers" },
            "rolloutToken": { "type": "string", "description": "Manual rollout token to force a restart when external provider content changes" }
          }
        },
        "themes": {
          "type": "object",
          "properties": {
            "existingConfigMap": { "type": "string", "description": "Existing ConfigMap mounted into /opt/keycloak/themes" },
            "existingSecret": { "type": "string", "description": "Existing Secret mounted into /opt/keycloak/themes" },
            "rolloutToken": { "type": "string", "description": "Manual rollout token to force a restart when external theme content changes" }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "description": "Kubernetes Service configuration",
      "properties": {
        "type": {
          "type": "string",
          "description": "Service type for application traffic",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the application service"
        },
        "managementAnnotations": {
          "type": "object",
          "description": "Annotations for the management service"
        },
        "ipFamilyPolicy": {
          "type": "string",
          "description": "Application Service IP family policy",
          "enum": ["", "SingleStack", "PreferDualStack", "RequireDualStack"]
        },
        "ipFamilies": {
          "type": "array",
          "description": "Application Service IP families",
          "maxItems": 2,
          "items": { "type": "string", "enum": ["IPv4", "IPv6"] }
        },
        "managementIpFamilyPolicy": {
          "type": "string",
          "description": "Management Service IP family policy",
          "enum": ["", "SingleStack", "PreferDualStack", "RequireDualStack"]
        },
        "managementIpFamilies": {
          "type": "array",
          "description": "Management Service IP families",
          "maxItems": 2,
          "items": { "type": "string", "enum": ["IPv4", "IPv6"] }
        }
      }
    },
    "gateway": {
      "type": "object",
      "description": "Gateway API HTTPRoute configuration",
      "properties": {
        "public": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "annotations": { "type": "object" },
            "parentRefs": { "type": "array", "items": { "type": "object" } },
            "hostnames": { "type": "array", "items": { "type": "string" } },
            "path": { "type": "string" },
            "pathType": { "type": "string", "enum": ["Exact", "PathPrefix", "RegularExpression"] },
            "filters": { "type": "array", "items": { "type": "object" } }
          }
        },
        "admin": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "annotations": { "type": "object" },
            "parentRefs": { "type": "array", "items": { "type": "object" } },
            "hostnames": { "type": "array", "items": { "type": "string" } },
            "path": { "type": "string" },
            "pathType": { "type": "string", "enum": ["Exact", "PathPrefix", "RegularExpression"] },
            "filters": { "type": "array", "items": { "type": "object" } }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "description": "Ingress configuration with separate public and admin ingresses",
      "properties": {
        "public": {
          "type": "object",
          "description": "Public UI and application endpoints ingress",
          "properties": {
            "enabled": { "type": "boolean", "description": "Enable ingress for Keycloak public UI and application endpoints" },
            "ingressClassName": { "type": "string", "description": "Ingress class name for the public ingress" },
            "annotations": { "type": "object" },
            "hosts": {
              "type": "array",
              "description": "Public ingress hosts",
              "items": {
                "type": "object",
                "properties": {
                  "host": { "type": "string" },
                  "paths": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "path": { "type": "string" },
                        "pathType": { "type": "string" }
                      }
                    }
                  }
                }
              }
            },
            "tls": {
              "type": "array",
              "description": "Public ingress TLS configuration",
              "items": {
                "type": "object",
                "properties": {
                  "hosts": { "type": "array", "items": { "type": "string" } },
                  "secretName": { "type": "string" }
                }
              }
            }
          }
        },
        "admin": {
          "type": "object",
          "description": "Admin console and admin endpoints ingress",
          "properties": {
            "enabled": { "type": "boolean", "description": "Enable a separate ingress for the admin console and admin endpoints" },
            "ingressClassName": { "type": "string", "description": "Ingress class name for the admin ingress" },
            "annotations": { "type": "object" },
            "hosts": {
              "type": "array",
              "description": "Admin ingress hosts",
              "items": {
                "type": "object",
                "properties": {
                  "host": { "type": "string" },
                  "paths": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "path": { "type": "string" },
                        "pathType": { "type": "string" }
                      }
                    }
                  }
                }
              }
            },
            "tls": {
              "type": "array",
              "description": "Admin ingress TLS configuration",
              "items": {
                "type": "object",
                "properties": {
                  "hosts": { "type": "array", "items": { "type": "string" } },
                  "secretName": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "health": {
      "type": "object",
      "description": "Keycloak health endpoints",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Keycloak health endpoints"
        }
      }
    },
    "probes": {
      "type": "object",
      "description": "Health probe configuration",
      "properties": {
        "profile": {
          "type": "string",
          "description": "Probe profile: default or heavy-startup",
          "enum": ["default", "heavy-startup"]
        },
        "liveness": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "description": "Enable the liveness probe" },
            "initialDelaySeconds": { "type": "integer" },
            "periodSeconds": { "type": "integer" },
            "timeoutSeconds": { "type": "integer" },
            "failureThreshold": { "type": "integer" }
          }
        },
        "readiness": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "description": "Enable the readiness probe" },
            "initialDelaySeconds": { "type": "integer" },
            "periodSeconds": { "type": "integer" },
            "timeoutSeconds": { "type": "integer" },
            "failureThreshold": { "type": "integer" }
          }
        },
        "startup": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "description": "Enable the startup probe" },
            "initialDelaySeconds": { "type": "integer" },
            "periodSeconds": { "type": "integer" },
            "timeoutSeconds": { "type": "integer" },
            "failureThreshold": { "type": "integer" }
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "description": "Keycloak metrics configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Keycloak metrics endpoint"
        },
        "userEvents": {
          "type": "boolean",
          "description": "Create metrics based on user events"
        },
        "cacheHistograms": {
          "type": "boolean",
          "description": "Enable cache metrics histograms"
        },
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "description": "Create a ServiceMonitor targeting the management service" },
            "interval": { "type": "string", "description": "Scrape interval" },
            "scrapeTimeout": { "type": "string", "description": "Scrape timeout" },
            "labels": { "type": "object", "description": "Additional labels for the ServiceMonitor" },
            "annotations": { "type": "object", "description": "Additional annotations for the ServiceMonitor" },
            "relabelings": { "type": "array", "items": { "type": "object" } },
            "metricRelabelings": { "type": "array", "items": { "type": "object" } }
          }
        }
      }
    },
    "telemetry": {
      "type": "object",
      "description": "OpenTelemetry metrics export settings",
      "properties": {
        "metricsEnabled": { "type": "boolean" },
        "endpoint": { "type": "string" },
        "metricsEndpoint": { "type": "string" }
      }
    },
    "tracing": {
      "type": "object",
      "description": "OpenTelemetry tracing settings",
      "properties": {
        "enabled": { "type": "boolean" },
        "endpoint": { "type": "string" },
        "samplerType": { "type": "string" },
        "samplerRatio": { "type": ["string", "number"] },
        "resourceAttributes": { "type": "string" },
        "jdbcEnabled": { "type": "boolean" },
        "infinispanEnabled": { "type": "boolean" }
      }
    },
    "logging": {
      "type": "object",
      "description": "Keycloak logging settings",
      "properties": {
        "level": { "type": "string" },
