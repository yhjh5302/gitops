            },
            "allowSameNamespacePostgreSQL": {
              "type": "boolean",
              "description": "Allow PostgreSQL egress to same-namespace pods for replication and internal checks.",
              "default": true
            },
            "allowHTTPS": {
              "type": "boolean",
              "description": "Allow HTTPS egress for S3-compatible backup endpoints.",
              "default": true
            }
          }
        }
      }
