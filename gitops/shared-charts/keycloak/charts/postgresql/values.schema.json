    "networkPolicy": {
      "type": "object",
      "description": "NetworkPolicy configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Create an ingress-only NetworkPolicy for PostgreSQL pods",
