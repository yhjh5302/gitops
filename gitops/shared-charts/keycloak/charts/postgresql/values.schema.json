{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "PostgreSQL Helm Chart Values",
  "description": "Configuration values for the PostgreSQL Helm chart. Supports standalone and replication architectures.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "architecture": {
      "type": "string",
      "description": "PostgreSQL deployment mode: standalone | replication",
      "enum": ["standalone", "replication"],
      "default": "standalone"
    },
    "nameOverride": {
      "type": "string",
      "description": "Override chart name",
      "default": ""
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override full release name",
      "default": ""
    },
    "commonLabels": {
      "type": "object",
      "description": "Labels added to all resources",
      "default": {}
    },
    "clusterDomain": {
      "type": "string",
      "description": "Kubernetes cluster domain",
      "default": "cluster.local"
    },
    "image": {
      "type": "object",
      "description": "PostgreSQL image configuration",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "description": "PostgreSQL image repository",
          "default": "docker.io/library/postgres"
        },
        "tag": {
          "type": "string",
          "description": "PostgreSQL image tag",
          "default": "18.4-trixie"
        },
        "pullPolicy": {
          "type": "string",
          "description": "Image pull policy",
          "enum": ["Always", "IfNotPresent", "Never"],
          "default": "IfNotPresent"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets",
      "items": {
        "type": "object"
      },
      "default": []
    },
    "auth": {
      "type": "object",
      "description": "PostgreSQL authentication configuration",
      "additionalProperties": false,
      "properties": {
        "postgresPassword": {
          "type": "string",
          "description": "PostgreSQL superuser password. Auto-generated only for a first install without persisted data when empty and no existingSecret is set.",
          "default": ""
        },
        "database": {
          "type": "string",
          "description": "Application database created on first bootstrap",
          "default": "app"
        },
        "username": {
          "type": "string",
          "description": "Application user created on first bootstrap",
          "default": "app"
        },
        "password": {
          "type": "string",
          "description": "Application user password. Auto-generated only for a first install without persisted data when empty and no existingSecret is set.",
          "default": ""
        },
        "replicationUsername": {
          "type": "string",
          "description": "Replication user used by read replicas",
          "default": "replicator"
        },
        "replicationPassword": {
          "type": "string",
          "description": "Replication user password. Auto-generated only for a first install without persisted data when empty and no existingSecret is set.",
          "default": ""
        },
        "allowPasswordGenerationWithExistingData": {
          "type": "boolean",
          "description": "Allow password generation even when an existing primary PVC is detected. Dangerous unless the data directory is empty.",
          "default": false
        },
        "existingSecret": {
          "type": "string",
          "description": "Existing secret with PostgreSQL passwords",
          "default": ""
        },
        "existingSecretPostgresPasswordKey": {
          "type": "string",
          "description": "Secret key for the PostgreSQL superuser password in auth.existingSecret",
          "default": "postgres-password"
        },
        "existingSecretUserPasswordKey": {
          "type": "string",
          "description": "Secret key for the application user password in auth.existingSecret",
          "default": "user-password"
        },
        "existingSecretReplicationPasswordKey": {
          "type": "string",
          "description": "Secret key for the replication user password in auth.existingSecret",
          "default": "replication-password"
        }
      }
    },
    "config": {
      "type": "object",
      "description": "PostgreSQL configuration",
      "additionalProperties": false,
      "properties": {
        "localAuthMethod": {
          "type": "string",
          "description": "Authentication method for local Unix-socket connections in pg_hba.conf.",
          "default": "scram-sha-256"
        },
        "allowedClientCIDRs": {
          "type": "array",
          "description": "CIDRs allowed to connect to regular PostgreSQL databases in generated pg_hba.conf.",
          "items": {
            "type": "string"
          },
          "default": ["0.0.0.0/0", "::/0"]
        },
        "allowedReplicationCIDRs": {
          "type": "array",
          "description": "CIDRs allowed to connect to the replication pseudo-database in generated pg_hba.conf.",
          "items": {
            "type": "string"
          },
          "default": ["0.0.0.0/0", "::/0"]
        },
        "preset": {
          "type": "string",
          "description": "Optional configuration preset: none | small | medium | large",
          "enum": ["none", "small", "medium", "large"],
          "default": "small"
        },
        "postgresql": {
          "type": "string",
          "description": "Extra postgresql.conf content appended to the generated configuration",
          "default": ""
        },
        "pgHbaEntries": {
          "type": "array",
          "description": "Structured pg_hba.conf entries appended after the generated defaults",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "database": {
                "type": "string"
              },
              "user": {
                "type": "string"
              },
              "address": {
                "type": "string"
              },
              "method": {
                "type": "string"
              },
              "options": {
                "type": "string"
              }
            }
          },
          "default": []
        },
        "pgHba": {
          "type": "string",
          "description": "Extra pg_hba.conf content appended to the generated host-based authentication rules",
          "default": ""
        }
      }
    },
    "tls": {
      "type": "object",
      "description": "TLS configuration for PostgreSQL",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable TLS for PostgreSQL server and internal clients",
          "default": false
        },
        "existingSecret": {
          "type": "string",
          "description": "Existing secret containing server TLS materials",
          "default": ""
        },
        "certFilename": {
          "type": "string",
          "description": "Certificate filename in the TLS secret",
          "default": "tls.crt"
        },
        "keyFilename": {
          "type": "string",
          "description": "Private key filename in the TLS secret",
          "default": "tls.key"
        },
        "caFilename": {
          "type": "string",
          "description": "CA filename in the TLS secret",
          "default": "ca.crt"
        },
        "sslMode": {
          "type": "string",
          "description": "libpq sslmode used by internal probes, replication, and exporter",
          "default": "require"
        },
        "minProtocolVersion": {
          "type": "string",
          "description": "Minimum TLS protocol version accepted by PostgreSQL",
          "default": "TLSv1.2"
        },
        "volumePermissions": {
          "type": "object",
          "description": "TLS secret permission normalization init container settings",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Copy TLS secret material into an owned emptyDir and restrict the private key to 0600.",
              "default": false
            },
            "securityContext": {
              "type": "object",
              "description": "Security context for the TLS permission init container"
            }
          }
        }
      }
    },
    "externalSecrets": {
      "type": "object",
      "description": "External Secrets Operator integration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Render ExternalSecret resources for clusters that already run External Secrets Operator.",
          "default": false
        },
        "apiVersion": {
          "type": "string",
          "description": "ExternalSecret API version.",
          "default": "external-secrets.io/v1"
        },
        "refreshInterval": {
          "type": "string",
          "description": "Refresh interval used by rendered ExternalSecret resources.",
          "default": "1h"
        },
        "secretStoreRef": {
          "type": "object",
          "description": "SecretStore reference used by rendered ExternalSecret resources.",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "description": "SecretStore or ClusterSecretStore name. Required when externalSecrets.enabled=true.",
              "default": ""
            },
            "kind": {
              "type": "string",
              "description": "Secret store kind.",
              "enum": ["SecretStore", "ClusterSecretStore"],
              "default": "SecretStore"
            }
          }
        },
        "target": {
          "type": "object",
          "description": "ExternalSecret target settings.",
          "additionalProperties": false,
          "properties": {
            "creationPolicy": {
              "type": "string",
              "description": "ExternalSecret target creation policy.",
              "enum": ["Owner", "Orphan", "Merge", "None"],
              "default": "Owner"
            }
          }
        },
        "auth": {
          "type": "object",
          "description": "ExternalSecret settings for PostgreSQL auth credentials.",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Manage the PostgreSQL auth Secret with External Secrets Operator.",
              "default": false
            },
            "targetName": {
              "type": "string",
              "description": "Optional target Secret name. Defaults to the chart auth Secret name.",
              "default": ""
            },
            "postgresPasswordRemoteRef": {
              "type": "object",
              "description": "remoteRef for the PostgreSQL superuser password.",
              "additionalProperties": true,
              "properties": {
                "key": { "type": "string" },
                "property": { "type": "string" },
                "version": { "type": "string" }
              },
              "default": {}
            },
            "userPasswordRemoteRef": {
              "type": "object",
              "description": "remoteRef for the application user password.",
              "additionalProperties": true,
              "properties": {
                "key": { "type": "string" },
                "property": { "type": "string" },
                "version": { "type": "string" }
              },
              "default": {}
            },
            "replicationPasswordRemoteRef": {
              "type": "object",
              "description": "remoteRef for the replication user password.",
              "additionalProperties": true,
              "properties": {
                "key": { "type": "string" },
                "property": { "type": "string" },
                "version": { "type": "string" }
              },
              "default": {}
            }
          }
        },
        "tls": {
          "type": "object",
          "description": "ExternalSecret settings for PostgreSQL TLS material.",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Manage the TLS Secret with External Secrets Operator. Requires tls.enabled=true.",
              "default": false
            },
            "targetName": {
              "type": "string",
              "description": "Optional target Secret name. Defaults to the chart TLS Secret name.",
              "default": ""
            },
            "certRemoteRef": {
              "type": "object",
              "description": "remoteRef for the TLS certificate.",
              "additionalProperties": true,
              "properties": {
                "key": { "type": "string" },
                "property": { "type": "string" },
                "version": { "type": "string" }
              },
              "default": {}
            },
            "keyRemoteRef": {
              "type": "object",
              "description": "remoteRef for the TLS private key.",
              "additionalProperties": true,
              "properties": {
                "key": { "type": "string" },
                "property": { "type": "string" },
                "version": { "type": "string" }
              },
              "default": {}
            },
            "caRemoteRef": {
              "type": "object",
              "description": "remoteRef for the TLS CA certificate.",
              "additionalProperties": true,
              "properties": {
                "key": { "type": "string" },
                "property": { "type": "string" },
                "version": { "type": "string" }
              },
              "default": {}
            }
          }
        },
        "backup": {
          "type": "object",
          "description": "ExternalSecret settings for backup S3 credentials.",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Manage the backup S3 credential Secret with External Secrets Operator. Requires backup.enabled=true.",
              "default": false
            },
            "targetName": {
              "type": "string",
              "description": "Optional target Secret name. Defaults to the chart backup Secret name.",
              "default": ""
            },
            "accessKeyRemoteRef": {
              "type": "object",
              "description": "remoteRef for the S3 access key.",
              "additionalProperties": true,
              "properties": {
                "key": { "type": "string" },
                "property": { "type": "string" },
                "version": { "type": "string" }
              },
              "default": {}
            },
            "secretKeyRemoteRef": {
              "type": "object",
              "description": "remoteRef for the S3 secret key.",
              "additionalProperties": true,
              "properties": {
                "key": { "type": "string" },
                "property": { "type": "string" },
                "version": { "type": "string" }
              },
              "default": {}
            }
          }
        }
      }
    },
    "initdb": {
      "type": "object",
      "description": "Database initialization configuration",
      "additionalProperties": false,
      "properties": {
        "runDefaultScript": {
          "type": "boolean",
          "description": "Run the chart-generated first-boot script that creates the application database, application user, and replication user",
          "default": true
        },
        "scripts": {
          "type": "object",
          "description": "Additional init scripts written into docker-entrypoint-initdb.d",
          "default": {}
        },
        "existingConfigMap": {
          "type": "string",
          "description": "Existing ConfigMap mounted into docker-entrypoint-initdb.d in addition to the generated scripts",
          "default": ""
        }
      }
    },
    "standalone": {
      "type": "object",
      "description": "Standalone mode configuration",
      "additionalProperties": false,
      "properties": {
        "resourcesPreset": {
          "type": "string",
          "description": "Optional resource preset: none | small | medium | large",
          "enum": ["none", "small", "medium", "large"],
          "default": "none"
        },
        "persistence": {
          "type": "object",
          "description": "Persistence configuration for standalone mode",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable PVC for standalone mode",
              "default": true
            },
            "storageClass": {
              "type": "string",
              "description": "Storage class for standalone PVC",
              "default": ""
            },
            "accessModes": {
              "type": "array",
              "description": "Access modes for standalone PVC",
              "items": {
                "type": "string"
              },
              "default": ["ReadWriteOnce"]
            },
            "size": {
              "type": "string",
              "description": "PVC size for standalone mode",
              "default": "8Gi"
            }
          }
        },
        "resources": {
          "type": "object",
          "description": "Resources for standalone PostgreSQL"
        }
      }
    },
    "replication": {
      "type": "object",
      "description": "Replication mode configuration",
      "additionalProperties": false,
      "properties": {
        "primary": {
          "type": "object",
          "description": "Primary node configuration",
          "additionalProperties": false,
          "properties": {
            "resourcesPreset": {
              "type": "string",
              "description": "Optional resource preset: none | small | medium | large",
              "enum": ["none", "small", "medium", "large"],
              "default": "small"
            },
            "persistence": {
              "type": "object",
              "description": "Persistence configuration for the primary",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Enable PVC for the primary StatefulSet",
                  "default": true
                },
                "storageClass": {
                  "type": "string",
                  "description": "Storage class for primary PVCs",
                  "default": ""
                },
                "accessModes": {
                  "type": "array",
                  "description": "Access modes for primary PVCs",
                  "items": {
                    "type": "string"
                  },
                  "default": ["ReadWriteOnce"]
                },
                "size": {
                  "type": "string",
                  "description": "PVC size for the primary pod",
                  "default": "20Gi"
                }
              }
            },
            "resources": {
              "type": "object",
              "description": "Resources for the primary PostgreSQL pod"
            },
            "probes": {
              "type": "object",
              "description": "Probe configuration for the primary",
              "additionalProperties": false,
              "properties": {
                "requireWritable": {
                  "type": "boolean",
                  "description": "In replication mode, require the primary readiness check to confirm the pod is not in recovery mode",
                  "default": true
                }
              }
            }
          }
        },
        "readReplicas": {
          "type": "object",
          "description": "Read replica configuration",
          "additionalProperties": false,
          "properties": {
            "resourcesPreset": {
              "type": "string",
              "description": "Optional resource preset: none | small | medium | large",
              "enum": ["none", "small", "medium", "large"],
              "default": "small"
            },
            "replicaCount": {
              "type": "integer",
              "description": "Number of read replica pods",
              "minimum": 1,
              "default": 2
            },
            "persistence": {
              "type": "object",
              "description": "Persistence configuration for read replicas",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Enable PVCs for read replicas",
                  "default": true
                },
                "storageClass": {
                  "type": "string",
                  "description": "Storage class for replica PVCs",
                  "default": ""
                },
                "accessModes": {
                  "type": "array",
                  "description": "Access modes for replica PVCs",
                  "items": {
                    "type": "string"
                  },
                  "default": ["ReadWriteOnce"]
                },
                "size": {
                  "type": "string",
                  "description": "PVC size per read replica",
                  "default": "20Gi"
                }
              }
            },
            "resources": {
              "type": "object",
              "description": "Resources for read replica pods"
            },
            "probes": {
              "type": "object",
              "description": "Probe configuration for read replicas",
              "additionalProperties": false,
              "properties": {
                "requireRecoveryMode": {
                  "type": "boolean",
                  "description": "In replication mode, require replica readiness to confirm the pod is in recovery mode",
                  "default": true
                }
              }
            }
          }
        },
        "wal": {
          "type": "object",
          "description": "WAL configuration for replication",
          "additionalProperties": false,
          "properties": {
            "keepSize": {
              "type": "string",
              "description": "WAL retention kept locally for replicas and recovery workflows",
              "default": "512MB"
            },
            "maxSenders": {
              "type": "integer",
              "description": "Maximum WAL sender processes",
              "default": 10
            },
            "maxReplicationSlots": {
              "type": "integer",
              "description": "Maximum replication slots",
              "default": 10
            },
            "maxSlotWalKeepSize": {
              "type": "string",
              "description": "Maximum WAL retained by replication slots before PostgreSQL can invalidate lagging slots. Empty uses PostgreSQL default.",
              "default": ""
            },
            "idleReplicationSlotTimeout": {
              "type": "string",
              "description": "Timeout for inactive replication slots before invalidation. Empty uses PostgreSQL default.",
              "default": ""
            },
            "walSenderTimeout": {
              "type": "string",
              "description": "Timeout for WAL sender responses from standby servers. Empty uses PostgreSQL default.",
              "default": ""
            }
          }
        },
        "slots": {
          "type": "object",
          "description": "Physical replication slot configuration for read replicas",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Use physical replication slots for read replicas.",
              "default": false
            },
            "namePrefix": {
              "type": "string",
              "description": "Prefix used to build deterministic per-replica slot names.",
              "default": "replica",
              "pattern": "^[a-z0-9_]+$"
            }
          }
        },
        "pdb": {
          "type": "object",
          "description": "PodDisruptionBudget for replication mode",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable a PodDisruptionBudget by default in replication mode",
              "default": true
            },
            "minAvailable": {
              "type": "integer",
              "description": "Minimum available pods",
              "default": 1
            },
            "maxUnavailable": {
              "type": ["integer", "string"],
              "description": "Maximum unavailable pods",
              "default": ""
            }
          }
        },
        "scheduling": {
          "type": "object",
          "description": "Scheduling configuration for replication mode",
          "additionalProperties": false,
          "properties": {
            "enableDefaultPodAntiAffinity": {
              "type": "boolean",
              "description": "Enable opinionated default placement rules in replication mode when global affinity/topologySpreadConstraints are empty",
              "default": true
            },
            "enableDefaultTopologySpread": {
              "type": "boolean",
              "description": "Enable default topology spread constraints",
              "default": true
            },
            "topologyKey": {
              "type": "string",
              "description": "Topology key for scheduling",
              "default": "kubernetes.io/hostname"
            }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "description": "Service configuration",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Service type for PostgreSQL client access",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "default": "ClusterIP"
        },
        "annotations": {
          "type": "object",
          "description": "Annotations on the service",
          "default": {}
        },
        "primaryAnnotations": {
          "type": "object",
          "description": "Annotations on the primary service",
          "default": {}
        },
        "replicasAnnotations": {
          "type": "object",
          "description": "Annotations on the replicas service",
          "default": {}
        },
        "port": {
          "type": "integer",
          "description": "PostgreSQL listener port",
          "default": 5432
        },
        "metricsPort": {
          "type": "integer",
          "description": "Metrics port exposed when metrics.enabled=true",
          "default": 9187
        },
        "ipFamilyPolicy": {
          "type": "string",
          "description": "Service IP family policy. One of SingleStack, PreferDualStack, RequireDualStack. Omit for cluster default.",
          "enum": ["SingleStack", "PreferDualStack", "RequireDualStack"]
        },
        "ipFamilies": {
          "type": "array",
          "description": "Ordered list of IP families for the Service. Each entry is IPv4 or IPv6. Omit for cluster default.",
          "items": {
            "type": "string",
            "enum": ["IPv4", "IPv6"]
          },
          "maxItems": 2,
          "uniqueItems": true
        }
      }
    },
    "metrics": {
      "type": "object",
      "description": "Prometheus metrics exporter configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable postgres_exporter sidecar",
          "default": false
        },
        "resourcesPreset": {
          "type": "string",
          "description": "Optional resource preset for postgres_exporter: none | small | medium",
          "enum": ["none", "small", "medium"],
          "default": "small"
        },
        "service": {
          "type": "object",
          "description": "Metrics service configuration",
          "additionalProperties": false,
          "properties": {
            "annotations": {
              "type": "object",
              "description": "Annotations applied to metrics Services",
              "default": {}
            }
          }
        },
        "image": {
          "type": "object",
          "description": "postgres_exporter image configuration",
          "additionalProperties": false,
          "properties": {
            "repository": {
              "type": "string",
              "description": "postgres_exporter image repository",
              "default": "quay.io/prometheuscommunity/postgres-exporter"
            },
            "tag": {
              "type": "string",
              "description": "postgres_exporter image tag",
              "default": "v0.18.0"
            },
            "pullPolicy": {
              "type": "string",
              "description": "Image pull policy",
              "enum": ["Always", "IfNotPresent", "Never"],
              "default": "IfNotPresent"
            }
          }
        },
        "resources": {
          "type": "object",
          "description": "Resources for postgres_exporter"
        },
        "serviceMonitor": {
          "type": "object",
          "description": "ServiceMonitor configuration",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create a ServiceMonitor (requires Prometheus Operator)",
              "default": false
            },
            "interval": {
              "type": "string",
              "description": "Scrape interval",
              "default": "30s"
            },
            "labels": {
              "type": "object",
              "description": "Additional labels for the ServiceMonitor",
              "default": {}
            }
          }
        }
      }
    },
    "backup": {
      "type": "object",
      "description": "Backup CronJob configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable built-in backup CronJob support",
          "default": false
        },
        "schedule": {
          "type": "string",
          "description": "Backup schedule in Cron format",
          "default": "0 3 * * *"
        },
        "suspend": {
          "type": "boolean",
          "description": "Suspend backup execution",
          "default": false
        },
        "concurrencyPolicy": {
          "type": "string",
          "description": "CronJob concurrency policy",
          "enum": ["Allow", "Forbid", "Replace"],
          "default": "Forbid"
        },
        "successfulJobsHistoryLimit": {
          "type": "integer",
          "description": "Successful job history retained by the CronJob",
          "default": 3
        },
        "failedJobsHistoryLimit": {
          "type": "integer",
          "description": "Failed job history retained by the CronJob",
          "default": 3
        },
        "backoffLimit": {
          "type": "integer",
          "description": "Job backoff limit",
          "default": 1
        },
        "archivePrefix": {
          "type": "string",
          "description": "Prefix used in generated backup archive names",
          "default": "postgresql"
        },
        "resources": {
          "type": "object",
          "description": "Resources applied to the backup dump and upload containers"
        },
        "images": {
          "type": "object",
          "description": "Backup container images",
          "additionalProperties": false,
          "properties": {
            "uploader": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
            "repository": {
              "type": "string",
              "default": "docker.io/helmforge/mc"
            },
            "tag": {
              "type": "string",
              "default": "1.0.0"
            },
                "pullPolicy": {
                  "type": "string",
                  "enum": ["Always", "IfNotPresent", "Never"],
                  "default": "IfNotPresent"
                }
              }
            },
            "postgresql": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "repository": {
                  "type": "string",
                  "default": "docker.io/library/postgres"
                },
                "tag": {
                  "type": "string",
                  "default": "18.4-trixie"
                },
                "pullPolicy": {
                  "type": "string",
                  "enum": ["Always", "IfNotPresent", "Never"],
                  "default": "IfNotPresent"
                }
              }
            }
          }
        },
        "s3": {
          "type": "object",
          "description": "S3-compatible storage configuration for backups",
          "additionalProperties": false,
          "properties": {
            "endpoint": {
              "type": "string",
              "description": "S3-compatible endpoint URL, for example: https://s3.amazonaws.com or https://minio.example.com",
              "default": ""
            },
            "bucket": {
              "type": "string",
              "description": "Target bucket name",
              "default": ""
            },
            "prefix": {
              "type": "string",
              "description": "Optional key prefix inside the bucket",
              "default": "postgresql"
            },
            "createBucketIfNotExists": {
              "type": "boolean",
              "description": "Create the bucket automatically when it does not exist yet",
              "default": true
            },
            "existingSecret": {
              "type": "string",
              "description": "Existing secret containing access-key and secret-key",
              "default": ""
            },
            "existingSecretAccessKeyKey": {
              "type": "string",
              "description": "Secret key name for the access key inside backup.s3.existingSecret",
              "default": "access-key"
            },
            "existingSecretSecretKeyKey": {
              "type": "string",
              "description": "Secret key name for the secret key inside backup.s3.existingSecret",
              "default": "secret-key"
            },
            "accessKey": {
              "type": "string",
              "description": "Inline access key used when backup.s3.existingSecret is not set",
              "default": ""
            },
            "secretKey": {
              "type": "string",
              "description": "Inline secret key used when backup.s3.existingSecret is not set",
              "default": ""
            }
          }
        },
        "database": {
          "type": "object",
          "description": "Database dump configuration",
          "additionalProperties": false,
          "properties": {
            "pgDumpAllArgs": {
              "type": "string",
              "description": "Extra arguments passed to pg_dumpall",
              "default": "--clean --if-exists"
            }
          }
        }
      }
