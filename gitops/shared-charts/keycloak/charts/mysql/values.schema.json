{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "MySQL Helm Chart Values",
  "description": "Configuration values for the MySQL Helm chart. Supports standalone and replication architectures.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "architecture": {
      "type": "string",
      "description": "MySQL deployment mode: standalone | replication",
      "enum": ["standalone", "replication"],
      "default": "standalone"
    },
    "nameOverride": {
      "type": "string",
      "description": "Override chart name",
      "default": ""
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override full release name",
      "default": ""
    },
    "commonLabels": {
      "type": "object",
      "description": "Labels added to all resources",
      "default": {}
    },
    "clusterDomain": {
      "type": "string",
      "description": "Kubernetes cluster domain",
      "default": "cluster.local"
    },
    "image": {
      "type": "object",
      "description": "MySQL image configuration",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "description": "MySQL image repository",
          "default": "docker.io/library/mysql"
        },
        "tag": {
          "type": "string",
          "description": "MySQL image tag",
          "default": "9.7.1"
        },
        "pullPolicy": {
          "type": "string",
          "description": "Image pull policy",
          "enum": ["Always", "IfNotPresent", "Never"],
          "default": "IfNotPresent"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets",
      "items": {
        "type": "object"
      },
      "default": []
    },
    "auth": {
      "type": "object",
      "description": "MySQL authentication configuration",
      "additionalProperties": false,
      "properties": {
        "rootPassword": {
          "type": "string",
          "description": "MySQL root password. Auto-generated if empty and no existingSecret is set.",
          "default": ""
        },
        "database": {
          "type": "string",
          "description": "Application database created on first bootstrap",
          "default": "app"
        },
        "username": {
          "type": "string",
          "description": "Application user created on first bootstrap",
          "default": "app"
        },
        "password": {
          "type": "string",
          "description": "Application user password. Auto-generated if empty and no existingSecret is set.",
          "default": ""
        },
        "replicationUsername": {
          "type": "string",
          "description": "Replication user used by read replicas",
          "default": "replicator"
        },
        "replicationPassword": {
          "type": "string",
          "description": "Replication user password. Auto-generated if empty and no existingSecret is set.",
          "default": ""
        },
        "existingSecret": {
          "type": "string",
          "description": "Existing secret with MySQL passwords",
          "default": ""
        },
        "existingSecretRootPasswordKey": {
          "type": "string",
          "description": "Secret key for the MySQL root password in auth.existingSecret",
          "default": "mysql-root-password"
        },
        "existingSecretUserPasswordKey": {
          "type": "string",
          "description": "Secret key for the application user password in auth.existingSecret",
          "default": "mysql-user-password"
        },
        "existingSecretReplicationPasswordKey": {
          "type": "string",
          "description": "Secret key for the replication user password in auth.existingSecret",
          "default": "mysql-replication-password"
        }
      }
    },
    "config": {
      "type": "object",
      "description": "MySQL configuration",
      "additionalProperties": false,
      "properties": {
        "preset": {
          "type": "string",
          "description": "Optional configuration preset: none | small | medium | large | oltp | read-heavy | analytics",
          "enum": ["none", "small", "medium", "large", "oltp", "read-heavy", "analytics"],
          "default": "none"
        },
        "myCnf": {
          "type": "string",
          "description": "Extra my.cnf content appended to the generated configuration",
          "default": ""
        }
      }
    },
    "initdb": {
      "type": "object",
      "description": "Database initialization configuration",
      "additionalProperties": false,
      "properties": {
        "scripts": {
          "type": "object",
          "description": "Additional init scripts written into docker-entrypoint-initdb.d",
          "default": {}
        },
        "existingConfigMap": {
          "type": "string",
          "description": "Existing ConfigMap mounted into docker-entrypoint-initdb.d in addition to the generated scripts",
          "default": ""
        }
      }
    },
    "standalone": {
      "type": "object",
      "description": "Standalone mode configuration",
      "additionalProperties": false,
      "properties": {
        "serverId": {
          "type": "integer",
          "description": "Server ID used in standalone mode",
          "default": 1
        },
        "resourcesPreset": {
          "type": "string",
          "description": "Optional resource preset: none | small | medium | large",
          "enum": ["none", "small", "medium", "large"],
          "default": "none"
        },
        "persistence": {
          "type": "object",
          "description": "Persistence configuration for standalone mode",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable PVC for standalone mode",
              "default": true
            },
            "storageClass": {
              "type": "string",
              "description": "Storage class for standalone PVC",
              "default": ""
            },
            "accessModes": {
              "type": "array",
              "description": "Access modes for standalone PVC",
              "items": {
                "type": "string"
              },
              "default": ["ReadWriteOnce"]
            },
            "size": {
              "type": "string",
              "description": "PVC size for standalone mode",
              "default": "8Gi"
            }
          }
        },
        "resources": {
          "type": "object",
          "description": "Resources for standalone MySQL"
        }
      }
    },
    "replication": {
      "type": "object",
      "description": "Replication mode configuration",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "object",
          "description": "Source (primary) node configuration",
          "additionalProperties": false,
          "properties": {
            "serverId": {
              "type": "integer",
              "description": "Server ID used by the source pod",
              "default": 1
            },
            "resourcesPreset": {
              "type": "string",
              "description": "Optional resource preset: none | small | medium | large",
              "enum": ["none", "small", "medium", "large"],
              "default": "none"
            },
            "persistence": {
              "type": "object",
              "description": "Persistence configuration for the source",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Enable PVC for the source StatefulSet",
                  "default": true
                },
                "storageClass": {
                  "type": "string",
                  "description": "Storage class for source PVCs",
                  "default": ""
                },
                "accessModes": {
                  "type": "array",
                  "description": "Access modes for source PVCs",
                  "items": {
                    "type": "string"
                  },
                  "default": ["ReadWriteOnce"]
                },
                "size": {
                  "type": "string",
                  "description": "PVC size for the source pod",
                  "default": "20Gi"
                }
              }
            },
            "resources": {
              "type": "object",
              "description": "Resources for the source MySQL pod"
            },
            "probes": {
              "type": "object",
              "description": "Probe configuration for the source",
              "additionalProperties": false,
              "properties": {
                "requireWritable": {
                  "type": "boolean",
                  "description": "In replication mode, require the source readiness check to confirm the pod is writable",
                  "default": true
                }
              }
            }
          }
        },
        "readReplicas": {
          "type": "object",
          "description": "Read replica configuration",
          "additionalProperties": false,
          "properties": {
            "serverIdBase": {
              "type": "integer",
              "description": "Base server ID used to derive replica server IDs from pod ordinal",
              "default": 100
            },
            "resourcesPreset": {
              "type": "string",
              "description": "Optional resource preset: none | small | medium | large",
              "enum": ["none", "small", "medium", "large"],
              "default": "none"
            },
            "replicaCount": {
              "type": "integer",
              "description": "Number of read replica pods",
              "minimum": 1,
              "default": 2
            },
            "persistence": {
              "type": "object",
              "description": "Persistence configuration for read replicas",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Enable PVCs for read replicas",
                  "default": true
                },
                "storageClass": {
                  "type": "string",
                  "description": "Storage class for replica PVCs",
                  "default": ""
                },
                "accessModes": {
                  "type": "array",
                  "description": "Access modes for replica PVCs",
                  "items": {
                    "type": "string"
                  },
                  "default": ["ReadWriteOnce"]
                },
                "size": {
                  "type": "string",
                  "description": "PVC size per read replica",
                  "default": "20Gi"
                }
              }
            },
            "resources": {
              "type": "object",
              "description": "Resources for read replica pods"
            },
            "probes": {
              "type": "object",
              "description": "Probe configuration for read replicas",
              "additionalProperties": false,
              "properties": {
                "requireReadOnly": {
                  "type": "boolean",
                  "description": "In replication mode, require replica readiness to confirm the pod is read-only",
                  "default": true
                },
                "requireRunningReplication": {
                  "type": "boolean",
                  "description": "Optionally require the replica readiness check to confirm IO and SQL replication threads are running",
                  "default": false
                }
              }
            }
          }
        },
        "binlog": {
          "type": "object",
          "description": "Binary log configuration",
          "additionalProperties": false,
          "properties": {
            "format": {
              "type": "string",
              "description": "Binlog format used by the source",
              "enum": ["ROW", "STATEMENT", "MIXED"],
              "default": "ROW"
            },
            "retentionDays": {
              "type": "integer",
              "description": "Binlog retention in whole days. When greater than zero, this overrides expireLogsSeconds in the generated config.",
              "default": 7
            },
            "expireLogsSeconds": {
              "type": "integer",
              "description": "Binlog expiration in seconds",
              "default": 604800
            },
            "syncBinlog": {
              "type": "integer",
              "description": "sync_binlog value used by the source",
              "default": 1
            }
          }
        },
        "replicaTuning": {
          "type": "object",
          "description": "Replica tuning configuration",
          "additionalProperties": false,
          "properties": {
            "parallelWorkers": {
              "type": "integer",
              "description": "Number of parallel applier workers on replicas",
              "default": 4
            }
          }
        },
        "pdb": {
          "type": "object",
          "description": "PodDisruptionBudget for replication mode",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable a PodDisruptionBudget by default in replication mode",
              "default": true
            },
            "minAvailable": {
              "type": "integer",
              "description": "Minimum available pods",
              "default": 1
            },
            "maxUnavailable": {
              "type": ["integer", "string"],
              "description": "Maximum unavailable pods",
              "default": ""
            }
          }
        },
        "scheduling": {
          "type": "object",
          "description": "Scheduling configuration for replication mode",
          "additionalProperties": false,
          "properties": {
            "enableDefaultPodAntiAffinity": {
              "type": "boolean",
              "description": "Enable opinionated default placement rules in replication mode when global affinity/topologySpreadConstraints are empty",
              "default": true
            },
            "enableDefaultTopologySpread": {
              "type": "boolean",
              "description": "Enable default topology spread constraints",
              "default": true
            },
            "topologyKey": {
              "type": "string",
              "description": "Topology key for scheduling",
              "default": "kubernetes.io/hostname"
            }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "description": "Service configuration",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Service type for MySQL client access",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "default": "ClusterIP"
        },
        "annotations": {
          "type": "object",
          "description": "Annotations on the service",
          "default": {}
        },
        "sourceAnnotations": {
          "type": "object",
          "description": "Annotations on the source service",
          "default": {}
        },
        "replicasAnnotations": {
          "type": "object",
          "description": "Annotations on the replicas service",
          "default": {}
        },
        "port": {
          "type": "integer",
          "description": "MySQL listener port",
          "default": 3306
        },
        "metricsPort": {
          "type": "integer",
          "description": "Metrics port exposed when metrics.enabled=true",
          "default": 9104
        },
        "ipFamilyPolicy": {
          "type": "string",
          "description": "Service IP family policy. One of SingleStack, PreferDualStack, RequireDualStack. Omit for cluster default.",
          "enum": ["", "SingleStack", "PreferDualStack", "RequireDualStack"]
        },
        "ipFamilies": {
          "type": "array",
          "description": "Ordered list of IP families for the Service. Each entry is IPv4 or IPv6. Omit for cluster default.",
          "items": {
            "type": "string",
            "enum": ["IPv4", "IPv6"]
          },
          "maxItems": 2,
          "uniqueItems": true
        }
      }
    },
    "metrics": {
      "type": "object",
      "description": "Prometheus metrics exporter configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable mysqld-exporter sidecar",
          "default": false
        },
        "resourcesPreset": {
          "type": "string",
          "description": "Optional resource preset for mysqld-exporter: none | small | medium",
          "enum": ["none", "small", "medium"],
          "default": "none"
        },
        "service": {
          "type": "object",
          "description": "Metrics service configuration",
          "additionalProperties": false,
          "properties": {
            "annotations": {
              "type": "object",
              "description": "Annotations applied to metrics Services",
              "default": {}
            }
          }
        },
        "image": {
          "type": "object",
          "description": "mysqld-exporter image configuration",
          "additionalProperties": false,
          "properties": {
            "repository": {
              "type": "string",
              "description": "mysqld-exporter image repository",
              "default": "docker.io/prom/mysqld-exporter"
            },
            "tag": {
              "type": "string",
              "description": "mysqld-exporter image tag",
              "default": "v0.17.2"
            },
            "pullPolicy": {
              "type": "string",
              "description": "Image pull policy",
              "enum": ["Always", "IfNotPresent", "Never"],
              "default": "IfNotPresent"
            }
          }
        },
        "resources": {
          "type": "object",
          "description": "Resources for mysqld-exporter"
        },
        "serviceMonitor": {
          "type": "object",
          "description": "ServiceMonitor configuration",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create a ServiceMonitor (requires Prometheus Operator)",
              "default": false
            },
            "interval": {
              "type": "string",
              "description": "Scrape interval",
              "default": "30s"
            },
            "labels": {
              "type": "object",
              "description": "Additional labels for the ServiceMonitor",
              "default": {}
            }
          }
        }
      }
    },
    "tls": {
      "type": "object",
      "description": "TLS configuration for MySQL",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable MySQL server TLS using certificates from tls.existingSecret",
          "default": false
        },
        "existingSecret": {
          "type": "string",
          "description": "Existing Secret containing TLS material for the MySQL server",
          "default": ""
        },
        "caFilename": {
          "type": "string",
          "description": "Secret key for the CA certificate in tls.existingSecret",
          "default": "ca.crt"
        },
        "certFilename": {
          "type": "string",
          "description": "Secret key for the server certificate in tls.existingSecret",
          "default": "tls.crt"
        },
        "keyFilename": {
          "type": "string",
          "description": "Secret key for the server private key in tls.existingSecret",
          "default": "tls.key"
        },
        "requireSecureTransport": {
          "type": "boolean",
          "description": "Require TLS for TCP client connections handled by mysqld",
          "default": false
        },
        "volumePermissions": {
          "type": "object",
          "description": "TLS volume permission normalization",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Copy TLS files to an emptyDir and normalize ownership/mode before mysqld starts",
              "default": false
            }
          }
        },
        "client": {
          "type": "object",
          "description": "Client TLS configuration",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable TLS for internal chart-managed TCP clients such as replication bootstrap commands",
              "default": false
            },
            "sslMode": {
              "type": "string",
              "description": "SSL mode used by mysql CLI tools when tls.client.enabled=true",
              "enum": ["PREFERRED", "REQUIRED", "VERIFY_CA"],
              "default": "REQUIRED"
            }
          }
        }
      }
    },
    "backup": {
      "type": "object",
      "description": "Backup CronJob configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable built-in backup CronJob support",
          "default": false
        },
        "schedule": {
          "type": "string",
          "description": "Backup schedule in Cron format",
          "default": "0 3 * * *"
        },
        "suspend": {
          "type": "boolean",
          "description": "Suspend backup execution",
          "default": false
        },
        "concurrencyPolicy": {
          "type": "string",
          "description": "CronJob concurrency policy",
          "enum": ["Allow", "Forbid", "Replace"],
          "default": "Forbid"
        },
        "successfulJobsHistoryLimit": {
          "type": "integer",
          "description": "Successful job history retained by the CronJob",
          "default": 3
        },
        "failedJobsHistoryLimit": {
          "type": "integer",
          "description": "Failed job history retained by the CronJob",
          "default": 3
        },
        "backoffLimit": {
          "type": "integer",
          "description": "Job backoff limit",
          "default": 1
        },
        "archivePrefix": {
          "type": "string",
          "description": "Prefix used in generated backup archive names",
          "default": "mysql"
        },
        "resources": {
          "type": "object",
          "description": "Resources applied to the backup dump and upload containers"
        },
        "images": {
          "type": "object",
          "description": "Backup container images",
          "additionalProperties": false,
          "properties": {
            "uploader": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "repository": {
                  "type": "string",
                  "default": "docker.io/helmforge/mc"
                },
                "tag": {
                  "type": "string",
                  "default": "1.0.0"
                },
                "pullPolicy": {
                  "type": "string",
                  "enum": ["Always", "IfNotPresent", "Never"],
                  "default": "IfNotPresent"
                }
              }
            },
            "mysql": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "repository": {
                  "type": "string",
                  "default": "docker.io/library/mysql"
                },
                "tag": {
                  "type": "string",
                  "default": "9.7.1"
                },
                "pullPolicy": {
                  "type": "string",
                  "enum": ["Always", "IfNotPresent", "Never"],
                  "default": "IfNotPresent"
                }
              }
            }
          }
        },
        "s3": {
          "type": "object",
          "description": "S3-compatible storage configuration for backups",
          "additionalProperties": false,
          "properties": {
            "endpoint": {
              "type": "string",
              "description": "S3-compatible endpoint URL, for example: https://s3.amazonaws.com or https://minio.example.com",
              "default": ""
            },
            "bucket": {
              "type": "string",
              "description": "Target bucket name",
              "default": ""
            },
            "prefix": {
              "type": "string",
              "description": "Optional key prefix inside the bucket",
              "default": "mysql"
            },
            "createBucketIfNotExists": {
              "type": "boolean",
              "description": "Create the bucket automatically when it does not exist yet",
              "default": true
            },
            "existingSecret": {
              "type": "string",
              "description": "Existing secret containing access-key and secret-key",
              "default": ""
            },
            "existingSecretAccessKeyKey": {
              "type": "string",
              "description": "Secret key name for the access key inside backup.s3.existingSecret",
              "default": "access-key"
            },
            "existingSecretSecretKeyKey": {
              "type": "string",
              "description": "Secret key name for the secret key inside backup.s3.existingSecret",
              "default": "secret-key"
            },
            "accessKey": {
              "type": "string",
              "description": "Inline access key used when backup.s3.existingSecret is not set",
              "default": ""
            },
            "secretKey": {
              "type": "string",
              "description": "Inline secret key used when backup.s3.existingSecret is not set",
              "default": ""
            }
          }
        },
        "database": {
          "type": "object",
          "description": "Database dump configuration",
          "additionalProperties": false,
          "properties": {
            "mysqldumpArgs": {
              "type": "string",
              "description": "Extra arguments passed to mysqldump before the built-in --all-databases flag",
              "default": "--single-transaction --quick --skip-lock-tables --no-tablespaces --routines --events --triggers"
            }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "description": "NetworkPolicy configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Create an ingress-only NetworkPolicy for MySQL pods",
          "default": false
        },
        "ingress": {
          "type": "object",
          "description": "Ingress rules for the NetworkPolicy",
          "additionalProperties": false,
          "properties": {
            "allowSameNamespace": {
              "type": "boolean",
              "description": "Allow ingress from the same namespace",
              "default": true
            },
            "extraFrom": {
              "type": "array",
              "description": "Additional ingress from rules appended to the generated policy",
              "items": {
                "type": "object"
              },
              "default": []
            }
          }
        },
        "metrics": {
          "type": "object",
          "description": "Metrics NetworkPolicy rules",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Allow ingress to the metrics port when metrics.enabled=true",
              "default": false
            },
            "allowSameNamespace": {
              "type": "boolean",
              "description": "Allow metrics scraping from the same namespace",
              "default": true
            },
            "extraFrom": {
              "type": "array",
              "description": "Additional ingress from rules appended to the generated metrics policy rule",
              "items": {
                "type": "object"
              },
              "default": []
            }
          }
        },
        "egress": {
          "type": "object",
          "description": "Egress rules for the NetworkPolicy",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Add egress rules to the NetworkPolicy",
              "default": false
            },
            "allowDNS": {
              "type": "boolean",
              "description": "Allow DNS egress to kube-dns/CoreDNS",
              "default": true
            },
            "allowSameNamespaceMySQL": {
              "type": "boolean",
              "description": "Allow MySQL egress to pods in the same namespace",
              "default": true
            },
            "allowHTTPS": {
              "type": "boolean",
              "description": "Allow TCP/443 egress",
              "default": false
            },
            "extraTo": {
              "type": "array",
              "description": "Additional egress rules appended to the generated policy",
              "items": {
                "type": "object"
              },
              "default": []
            }
          }
        }
      }
    },
    "pdb": {
      "type": "object",
      "description": "PodDisruptionBudget configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable PodDisruptionBudget",
          "default": false
        },
        "minAvailable": {
